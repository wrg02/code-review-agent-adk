# Copy this file to .env and fill in the values.
# The .env file must never be committed (already covered by .gitignore).

# Gemini model configuration
# Option 1: Gemini API directly (without Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=your-gemini-api-key-here

# Option 2: Vertex AI (recommended for production on GCP)
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Rules source — choose one:
# For local development (no GCS):
LOCAL_RULES_DIR=rules/

# For production (GCS):
# RULES_BUCKET=governance-rules-your-project
