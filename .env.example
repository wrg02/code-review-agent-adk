# Copie este arquivo para .env e preencha os valores
# O arquivo .env nunca deve ser commitado (já está no .gitignore)

# Configuracao do modelo Gemini
# Opcao 1: Gemini API direto (sem Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=your-gemini-api-key-here

# Opcao 2: Vertex AI (recomendado em producao no GCP)
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Regras — escolha uma das opcoes:
# Para desenvolvimento local (sem GCS):
LOCAL_RULES_DIR=regras/

# Para producao (GCS):
# RULES_BUCKET=governance-rules-your-project
